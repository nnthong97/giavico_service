SPRING_DATASOURCE_DRIVER_CLASS_NAME=org.postgresql.Driver

# Use the Supabase session pooler connection string for Render if direct IPv6 is not available.
# Example:
# jdbc:postgresql://aws-0-ap-southeast-1.pooler.supabase.com:5432/postgres?sslmode=require
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres.gfpywsfecithbjyzhklo:qexTed-zoxzi5-sazpud@aws-1-us-east-1.pooler.supabase.com:5432/postgres
SPRING_DATASOURCE_USERNAME=postgres.gfpywsfecithbjyzhklo
SPRING_DATASOURCE_PASSWORD=qexTed-zoxzi5-sazpud

# Keep the pool small for Supabase pooler-friendly app hosting.
SPRING_DATASOURCE_HIKARI_MAXIMUM_POOL_SIZE=5
SPRING_DATASOURCE_HIKARI_MINIMUM_IDLE=1

SPRING_JPA_HIBERNATE_DDL_AUTO=update
GIAVICO_CORS_ALLOWED_ORIGINS=http://localhost:4200

# Render cannot reach Ollama on your laptop. Use a hosted Ollama-compatible endpoint in production.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma4
OLLAMA_CONNECT_TIMEOUT=PT10S
OLLAMA_TIMEOUT=PT5M
